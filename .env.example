# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Claude — story text generation. Pick ONE:
#
# A) Run it on your Claude subscription (Pro/Max), no API bill.
#    In a terminal run:  claude setup-token
#    Paste the token it prints here. Counts against your Claude usage limits.
#    Good for local, personal use.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat...
#
#    Also set CLAUDE_CLI_BIN to the absolute path of the `claude` binary so the
#    server can find it (subscription generation shells out to the CLI, since
#    subscription tokens are only accepted through Claude Code's own request path):
# CLAUDE_CLI_BIN=/absolute/path/to/claude
#
# B) Pay-as-you-go API key (required for a real/shared deployment).
# ANTHROPIC_API_KEY=sk-ant-api...

# Optional: real illustration generation. Without a key the app ships
# playful built-in placeholder art, so the whole loop works keyless.
# IMAGE_PROVIDER=openai
# OPENAI_API_KEY=sk-...
