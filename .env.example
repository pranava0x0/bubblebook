# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Anthropic — story text generation.
# Local dev needs NO key here if you've run `ant auth login` once (the SDK
# reads the OAuth profile from ~/.config/anthropic automatically).
# Set a key only for deployments, or to override the profile:
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: real illustration generation. Without a key the app ships
# playful built-in placeholder art, so the whole loop works keyless.
# IMAGE_PROVIDER=openai
# OPENAI_API_KEY=sk-...
